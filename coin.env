# Coin-specific config for the Flux HA masternode template.
# The generic scripts are identical across coins; only this file changes per coin.
COIN_TICKER="DASH"
COIN_DAEMON="dashd"
COIN_CLI_BIN="dash-cli"
DATADIR="/root/.dashcore"               # default dir .dashcore
CONF="${DATADIR}/dash.conf"
MN_PORT=9999                            # Dash mainnet masternode P2P port
BLS_PARAM="masternodeblsprivkey"        # Dash uses the masternode key name
SEED_NODES=""
CLI="${COIN_CLI_BIN} -datadir=${DATADIR} -conf=${CONF}"
